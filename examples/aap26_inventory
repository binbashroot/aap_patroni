[all:vars]
bundle_install=true
bundle_dir='{{ lookup("ansible.builtin.env", "PWD") }}/bundle'

# Certificates
certs_dir='{{ lookup("ansible.builtin.env", "PWD") }}/certs'
custom_ca_cert='{{ certs_dir }}/ca.crt'
controller_tls_cert='{{ certs_dir }}/wildcard-example.com.crt'
controller_tls_key='{{ certs_dir }}/wildcard-example.com.key'
eda_tls_cert='{{ certs_dir }}/wildcard-example.com.crt'
eda_tls_key='{{ certs_dir }}/wildcard-example.com.key'
gateway_tls_cert='{{ certs_dir }}/wildcard-example.com.crt'
gateway_tls_key='{{ certs_dir }}/wildcard-example.com.key'
hub_tls_cert='{{ certs_dir }}/wildcard-example.com.crt'
hub_tls_key='{{ certs_dir }}/wildcard-example.com.key'

# NFS HUB
hub_shared_data_mount_opts='rw,sync,hard'
hub_shared_data_path='lockerstor.example.com:/volume2/hub-cl'
hub_seed_collections=false
gateway_main_url='https://aap-lb.example.com'

# Postgres Stuff
#gateway_pg_host=aapdb.example.com
gateway_pg_host=localhost
gateway_pg_port=5000
gateway_pg_database=automationgateway
gateway_pg_username=automationgateway

#controller_pg_host=aapdb.example.com
controller_pg_host=localhost
controller_pg_port=5000
controller_pg_database=automationcontroller
controller_pg_username=automationcontroller

#hub_pg_host=aapdb.example.com
hub_pg_host=localhost
hub_pg_port=5000
hub_pg_database=automationhub
hub_pg_username=automationhub

#eda_pg_host=aapdb.example.com
eda_pg_host=localhost
eda_pg_port=5000
eda_pg_database=automationeda
eda_pg_username=automationeda

postgresql_admin_username=postgres

# AAP Lightspeed
# https://docs.redhat.com/en/documentation/red_hat_ansible_automation_platform/2.6/html/containerized_installation/appendix-inventory-files-vars#ref-lightspeed-variables
