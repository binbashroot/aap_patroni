# Installation inventory for AAP using a patroni 3 node PG cluster
# with an HAproxy service on each AAP service node.
# You will also need an haproxy service on your deployment host
# The deployment node haproxy service can be turned down afterwards

[automationgateway]
aapgtwy1.example.com
aapgtwy2.example.com

[automationcontroller]
