# /etc/patroni/patroni.yml
# Managed by Ansible — do not edit manually
# Node: {{ inventory_hostname }}

scope: postgres-cluster
namespace: /patroni/
name: {{ ansible_hostname }}

restapi:
  listen: '{{ ansible_default_ipv4['address'] }}:8008'
  connect_address: '{{ ansible_default_ipv4['address'] }}:8008'

etcd3:
  hosts: >-
    {% for host in groups['pgcluster'] -%}
    {{ hostvars[host]['ansible_default_ipv4']['address'] }}:2379
    {%- if not loop.last %},{% endif %}
    {%- endfor %}

bootstrap:
  dcs:
    ttl: 30
    loop_wait: 10
    retry_timeout: 10
    maximum_lag_on_failover: 1048576
    postgresql:
      use_pg_rewind: true
      use_slots: true
      parameters:
        wal_level: replica
        hot_standby: 'on'
        max_connections: 200
        max_wal_senders: 10
        max_replication_slots: 10
        wal_log_hints: 'on'

  initdb:
    - encoding: UTF8
    - data-checksums

  pg_hba:
    - host replication replicator samenet scram-sha-256 
    - host awx awx samenet scram-sha-256
    - host eda eda samenet scram-sha-256
    - host gateway gateway samenet scram-sha-256
    - host pulp pulp samenet scram-sha-256
    - host automationcontroller automationcontroller samenet scram-sha-256
    - host automationhub automationhub samenet scram-sha-256
    - host automationeda automationeda samenet scram-sha-256
    - host automationgateway automationgateway samenet scram-sha-256
    - host all postgres samenet scram-sha-256
# This file uses both the default aap users/database names as well
# as the custom ones defined in the example aap 2.6 inventory
  users:
    awx:
      password: changeme
    eda:
      password: changeme
    gateway:
      password: changeme
    pulp:
      password: changeme
    automationcontroller:
      password: changeme
    automationeda:
      password: changeme
    automationgateway:
      password: changeme
    automationhub:
      password: changeme
    postgres:
      password: changeme
    replicator:
      password: changeme
      options:
        - replication

postgresql:
  listen: '{{ ansible_default_ipv4['address'] }}:5432'
  connect_address: '{{ ansible_default_ipv4['address'] }}:5432'
  data_dir: /var/lib/pgsql/data
  bin_dir: /usr/bin
  pgpass: /var/lib/pgsql/.pgpass
  authentication:
    replication:
      username: replicator
      password: changeme
    superuser:
      username: postgres
      password: changeme
    rewind:
      username: rewind_user
      password: changeme
  parameters:
    unix_socket_directories: /var/run/postgresql
    password_encryption: scram-sha-256
tags:
  nofailover: false
  noloadbalance: false
  clonefrom: false
  nosync: false

# Update the watchdog settings when you use Patroni in
# production
watchdog:
  mode: off
